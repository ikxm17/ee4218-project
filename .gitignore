#########################################################################################
##  EDA tools gitignore (adapted from https://github.com/iDoka/eda-scripts)            ##
#########################################################################################

# log files
*.log
*.rpt

# bitstream
*.bit

# netlist
*.edf
*.edif
*.vn

# SDF
*.sdf

# for Xilinx Vivado|ISE
.Xil/
.hbs/
.cache/
xsim.dir/
*.ip_user_files/

worklib.tb.wdb
fsm_encoding.os
tab_*/
webtalk.jou
webtalk.log
webtalk_*.jou
webtalk_*.log
vivado.jou
vivado.log
vivado_pid*.str
hs_err_pid*
xelab.*
xsim.*
xvlog.*
*.cache
*.sim
*.runs
*.hw
*.backup.*
*.debug
*.gen
*.dcp
**/utils_1/

unisims

# for Vitis
_ide/

#########################################################################################
##  Build outputs                                                                      ##
#########################################################################################

# Vivado IP repo — derived cache populated by scripts/sync-ip-src.sh
# from hardware/rtl/ and hardware/weights/hdl/. Canonical source is rtl/.
hardware/ip_repo/*
!hardware/ip_repo/.gitkeep

# Vivado export artifacts
hardware/output/*
!hardware/output/.gitkeep
# Preserved bitstreams — known-working builds kept for forensics.
# Never auto-overwritten by rebuild_bitstream.tcl (which only touches the
# top-level hardware/output/playground.* files). Files here should be
# named with the md5 prefix, e.g. playground_FIXED_5e86ce6c.bit
!hardware/output/preserved/
!hardware/output/preserved/**

# Vivado block design transient files
*.bda
**/bd/*/ui/

# Python
__pycache__/
venv/

# Training data
coco3/

# Inference outputs
software/tflite_script/